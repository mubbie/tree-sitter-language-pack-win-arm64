<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <LangVersion>latest</LangVersion>

    <PackageId>TreeSitterLanguagePack</PackageId>
    <Version>1.0.0-rc.6</Version>
    <Authors>kreuzberg-dev</Authors>
    <Company>kreuzberg-dev</Company>
    <Description>Tree-sitter language pack - pre-compiled parsers for 170+ languages (.NET P/Invoke bindings)</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/kreuzberg-dev/tree-sitter-language-pack</PackageProjectUrl>
    <RepositoryUrl>https://github.com/kreuzberg-dev/tree-sitter-language-pack</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>tree-sitter;parser;syntax;ast;language-pack;ffi;dotnet;netcore</PackageTags>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="runtimes/**" Pack="true" PackagePath="runtimes/" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <!-- Copy native libraries from FFI build output to runtimes directory.
       In CI: artifacts are downloaded to runtimes/ before build.
       Locally: this target copies from target/release for single-platform development builds. -->
  <Target Name="CopyNativeLibraries" BeforeTargets="Build">
    <PropertyGroup>
      <RuntimesDir>$(MSBuildThisFileDirectory)runtimes</RuntimesDir>
      <FfiReleaseDir>$(MSBuildThisFileDirectory)../../../target/release</FfiReleaseDir>
      <RuntimesAlreadyPopulated Condition="Exists('$(RuntimesDir)/linux-x64/native') OR Exists('$(RuntimesDir)/win-x64/native')">true</RuntimesAlreadyPopulated>
    </PropertyGroup>

    <Message Text="Native libraries already exist in runtimes/ directory (CI artifacts). Skipping copy." Condition="'$(RuntimesAlreadyPopulated)' == 'true'" Importance="high" />
  </Target>

  <Target Name="PerformNativeLibraryCopy" BeforeTargets="Build" Condition="'$(RuntimesAlreadyPopulated)' != 'true'">
    <PropertyGroup>
      <RuntimesDir>$(MSBuildThisFileDirectory)runtimes</RuntimesDir>
      <FfiReleaseDir>$(MSBuildThisFileDirectory)../../../target/release</FfiReleaseDir>
    </PropertyGroup>

    <!-- macOS arm64 -->
    <MakeDir Directories="$(RuntimesDir)/osx-arm64/native" />
    <Copy SourceFiles="$(FfiReleaseDir)/libts_pack_ffi.dylib" DestinationFolder="$(RuntimesDir)/osx-arm64/native" Condition="Exists('$(FfiReleaseDir)/libts_pack_ffi.dylib')" />

    <!-- macOS x64 -->
    <MakeDir Directories="$(RuntimesDir)/osx-x64/native" />
    <Copy SourceFiles="$(FfiReleaseDir)/libts_pack_ffi.dylib" DestinationFolder="$(RuntimesDir)/osx-x64/native" Condition="Exists('$(FfiReleaseDir)/libts_pack_ffi.dylib')" />

    <!-- Linux x64 -->
    <MakeDir Directories="$(RuntimesDir)/linux-x64/native" />
    <Copy SourceFiles="$(FfiReleaseDir)/libts_pack_ffi.so" DestinationFolder="$(RuntimesDir)/linux-x64/native" Condition="Exists('$(FfiReleaseDir)/libts_pack_ffi.so')" />

    <!-- Linux arm64 -->
    <MakeDir Directories="$(RuntimesDir)/linux-arm64/native" />
    <Copy SourceFiles="$(FfiReleaseDir)/libts_pack_ffi.so" DestinationFolder="$(RuntimesDir)/linux-arm64/native" Condition="Exists('$(FfiReleaseDir)/libts_pack_ffi.so')" />

    <!-- Windows x64 -->
    <MakeDir Directories="$(RuntimesDir)/win-x64/native" />
    <Copy SourceFiles="$(FfiReleaseDir)/ts_pack_ffi.dll" DestinationFolder="$(RuntimesDir)/win-x64/native" Condition="Exists('$(FfiReleaseDir)/ts_pack_ffi.dll')" />

    <!-- Windows arm64 -->
    <MakeDir Directories="$(RuntimesDir)/win-arm64/native" />
    <Copy SourceFiles="$(FfiReleaseDir)/ts_pack_ffi.dll" DestinationFolder="$(RuntimesDir)/win-arm64/native" Condition="Exists('$(FfiReleaseDir)/ts_pack_ffi.dll')" />

    <Message Text="Native libraries copied to $(RuntimesDir)" Importance="high" />
  </Target>
</Project>
